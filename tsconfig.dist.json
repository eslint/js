{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true
  },
  "include": ["packages/*/dist", "packages/*/tests/types"]
}

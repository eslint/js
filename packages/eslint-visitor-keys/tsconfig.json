{
  "compilerOptions": {
    "lib": ["esnext"],
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "lib",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "target": "es6",
    "outDir": "dist"
  },
  "include": ["lib/**/*.js"],
  "exclude": ["node_modules"]
}
